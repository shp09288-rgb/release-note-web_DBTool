# ============================================================
# Supabase 연결 설정 (이 파일을 .env.local로 복사 후 값 입력)
# ============================================================

# Supabase 프로젝트 URL
# Supabase 대시보드 → Project Settings → API → Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (공개용, 브라우저에서 사용 가능)
# Supabase 대시보드 → Project Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role Key (서버 전용, 절대 공개하지 말 것)
# Supabase 대시보드 → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
